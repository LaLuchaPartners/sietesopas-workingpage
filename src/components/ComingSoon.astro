---
import '../styles/global.css';

// Note: Using 'proximamante.svg' as found in the public folder.
// If the filename changes, update it here.
---

<div class="relative min-h-screen w-full flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <img 
    src="/fondo.svg" 
    alt="Background" 
    class="bg-svg-fullscreen animate-fade-in"
    loading="eager"
  />
  
  <!-- Overlay -->
  <div class="bg-overlay animate-fade-in delay-300"></div>

  <!-- Content Container -->
  <main class="relative z-10 flex flex-col items-center justify-between h-screen py-12 md:py-16 animate-float">
    
    <!-- Header: Title and Logo together at top -->
    <div class="flex flex-col items-center gap-4">
      <!-- Title: Próximamente -->
      <div class="animate-fade-in delay-500 w-[80%] max-w-[400px] md:max-w-[500px]">
        <img 
          src="/proximamante.svg" 
          alt="Próximamente" 
          class="w-full h-auto"
        />
      </div>

      <!-- Logo -->
      <div class="animate-fade-in delay-700 w-[100px] md:w-[120px]">
        <img 
          src="/logo.svg" 
          alt="Siete Sopas Logo" 
          class="w-full h-auto drop-shadow-lg"
        />
      </div>
    </div>

    <!-- Buttons Container -->
    <div class="flex flex-col items-center gap-4 md:gap-6 animate-fade-in delay-900 mb-10">
      
      <!-- Button: Facturación -->
      <a 
        href="#" 
        class="group relative flex items-center justify-center transition-transform duration-300 hover:scale-105 button-glow active:scale-95"
        aria-label="Facturación"
      >
        <!-- Button Background -->
        <img 
          src="/boton1.svg" 
          alt="" 
          class="w-[140px] md:w-[160px] h-auto"
        />
        <!-- Button Text -->
        <div class="absolute inset-0 flex items-center justify-center p-4">
          <span class="button-text text-lg md:text-xl lg:text-2xl transition-all duration-300 group-hover:brightness-110">
            Facturación
          </span>
        </div>
      </a>

      <!-- Button: Libro de Reclamaciones -->
      <a 
        href="#" 
        class="group relative flex items-center justify-center transition-transform duration-300 hover:scale-105 button-glow active:scale-95"
        aria-label="Libro de Reclamaciones"
      >
        <!-- Button Background -->
        <img 
          src="/boton2.svg" 
          alt="" 
          class="w-[240px] md:w-[260px] h-auto"
        />
        <!-- Button Text -->
        <div class="absolute inset-0 flex items-center justify-center p-4">
          <span class="button-text text-lg md:text-xl lg:text-2xl transition-all duration-300 group-hover:brightness-110">
            Libro de reclamaciones
          </span>
        </div>
      </a>

    </div>
  </main>
</div>

<style>
  /* Additional fine-tuning if needed */
  main {
    /* Use clamp for better responsiveness of the main container width */
    width: clamp(300px, 90%, 800px);
  }
</style>
